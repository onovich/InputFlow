{
  "name": "inputflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "browser:install": "playwright install chromium firefox webkit",
    "browser:test": "playwright test --project=chromium",
    "browser:test:all": "playwright test",
    "browser:test:list": "playwright test --list",
    "build": "tsc -b tsconfig.json --pretty false",
    "docs:check": "node scripts/check-docs.mjs",
    "lint": "node scripts/lint.mjs",
    "package:dry-run": "node scripts/package-dry-run.mjs",
    "release:dry-run": "pnpm browser:test && pnpm package:dry-run",
    "structure:check": "node scripts/check-structure.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b tsconfig.json --pretty false",
    "validate": "pnpm lint && pnpm typecheck && pnpm build && pnpm test && pnpm structure:check && pnpm docs:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
